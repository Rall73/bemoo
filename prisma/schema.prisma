generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────

enum LegalType {
  TERMS
  PRIVACY
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  ADMIN
  GESTOR
  EXECUTOR
  AUDITOR
}

// ─── Core: Empresa e Usuários ─────────────────────────────────────

model Company {
  id          Int       @id @default(autoincrement())
  name        String
  document    String?
  email       String    @unique
  plan        Plan      @default(FREE)
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")
  suspendedAt  DateTime? @map("suspended_at")
  featureAudio Boolean   @default(false) @map("feature_audio")

  users      User[]
  modules    CompanyModule[]
  auditLogs  AuditLog[]
  checklists Checklist[]
  executions ChecklistExecution[]

  @@map("companies")
}

model User {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EXECUTOR)
  platformAdmin Boolean   @default(false) @map("platform_admin")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     Int?      @map("deleted_by")

  company              Company              @relation(fields: [companyId], references: [id])
  legalAcceptances     LegalAcceptance[]
  auditLogs            AuditLog[]
  checklistsCreated    Checklist[]          @relation("ChecklistCreator")
  checklistExecutions  ChecklistExecution[] @relation("ChecklistExecutor")

  @@index([companyId])
  @@map("users")
}

// ─── Auditoria ────────────────────────────────────────────────────

model AuditLog {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  userId        Int       @map("user_id")
  action        String    @db.VarChar(100)
  entity        String?   @db.VarChar(100)
  entityId      Int?      @map("entity_id")
  payloadBefore String?   @db.Text @map("payload_before")
  payloadAfter  String?   @db.Text @map("payload_after")
  ip            String?   @db.VarChar(45)
  createdAt     DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId],    references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Auth: convites e reset de senha ─────────────────────────────

model Invite {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  email       String
  role        Role      @default(EXECUTOR)
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([token])
  @@map("invites")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@map("password_resets")
}

// ─── Documentos legais e aceites ─────────────────────────────────

model LegalVersion {
  id          Int               @id @default(autoincrement())
  type        LegalType
  version     String            @db.VarChar(20)
  summary     String?           @db.Text
  effectiveAt DateTime          @map("effective_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  createdBy   Int               @map("created_by")
  acceptances LegalAcceptance[]

  @@unique([type, version])
  @@index([type, effectiveAt])
  @@map("legal_versions")
}

model LegalAcceptance {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  legalVersionId Int          @map("legal_version_id")
  acceptedAt     DateTime     @default(now()) @map("accepted_at")
  ip             String?      @db.VarChar(45)
  user           User         @relation(fields: [userId], references: [id])
  legalVersion   LegalVersion @relation(fields: [legalVersionId], references: [id])

  @@unique([userId, legalVersionId])
  @@index([userId])
  @@map("legal_acceptances")
}

// ─── Checklists ───────────────────────────────────────────────────

enum ChecklistItemType {
  BOOLEAN
  TEXT
  NUMBER
  TEMPERATURE
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Checklist {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  name        String    @db.VarChar(200)
  description String?   @db.Text
  active      Boolean   @default(true)
  createdBy   Int       @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   Int?      @map("deleted_by")

  company    Company              @relation(fields: [companyId], references: [id])
  creator    User                 @relation("ChecklistCreator", fields: [createdBy], references: [id])
  items      ChecklistItem[]
  executions ChecklistExecution[]

  @@index([companyId])
  @@map("checklists")
}

model ChecklistItem {
  id          Int               @id @default(autoincrement())
  checklistId Int               @map("checklist_id")
  order       Int               @default(0)
  label       String            @db.VarChar(500)
  description String?           @db.Text
  required    Boolean           @default(true)
  type        ChecklistItemType @default(BOOLEAN)
  deletedAt   DateTime?         @map("deleted_at")
  deletedBy   Int?              @map("deleted_by")

  checklist Checklist       @relation(fields: [checklistId], references: [id])
  execItems ExecutionItem[]

  @@index([checklistId])
  @@map("checklist_items")
}

model ChecklistExecution {
  id                  Int             @id @default(autoincrement())
  checklistId         Int             @map("checklist_id")
  companyId           Int             @map("company_id")
  executedBy          Int             @map("executed_by")
  status              ExecutionStatus @default(IN_PROGRESS)
  startedAt           DateTime        @default(now()) @map("started_at")
  finishedAt          DateTime?       @map("finished_at")
  conclusionNote      String?         @db.Text @map("conclusion_note")
  reportUrl           String?         @db.VarChar(500) @map("report_url")
  reportGeneratedAt   DateTime?       @map("report_generated_at")
  deletedAt           DateTime?       @map("deleted_at")
  deletedBy           Int?            @map("deleted_by")

  checklist Checklist       @relation(fields: [checklistId], references: [id])
  company   Company         @relation(fields: [companyId], references: [id])
  executor  User            @relation("ChecklistExecutor", fields: [executedBy], references: [id])
  items     ExecutionItem[]

  @@index([companyId])
  @@index([checklistId])
  @@index([executedBy])
  @@map("checklist_executions")
}

model ExecutionItem {
  id              Int       @id @default(autoincrement())
  executionId     Int       @map("execution_id")
  checklistItemId Int       @map("checklist_item_id")
  conformant      Boolean?
  value           String?   @db.Text
  annotation      String?   @db.Text
  transcription   String?   @db.Text
  photoUrl        String?   @db.VarChar(500) @map("photo_url")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  execution     ChecklistExecution @relation(fields: [executionId], references: [id])
  checklistItem ChecklistItem      @relation(fields: [checklistItemId], references: [id])

  @@unique([executionId, checklistItemId])
  @@index([executionId])
  @@map("execution_items")
}

// ─── Módulos habilitados por empresa ─────────────────────────────

model CompanyModule {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  module    String   // checklists | intercorrencias | rastreabilidade | planos | captura
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, module])
  @@index([companyId])
  @@map("company_modules")
}
