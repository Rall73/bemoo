generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────

enum LegalType {
  TERMS
  PRIVACY
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  ADMIN
  GESTOR
  EXECUTOR
  AUDITOR
}

// ─── Core: Empresa e Usuários ─────────────────────────────────────

model Company {
  id          Int       @id @default(autoincrement())
  name        String
  document    String?
  email       String    @unique
  plan        Plan      @default(FREE)
  maxUsers    Int?      @map("max_users")   // null = usa o limite padrão do plano
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")
  suspendedAt  DateTime? @map("suspended_at")
  featureAudio Boolean   @default(false) @map("feature_audio")

  users      User[]
  modules    CompanyModule[]
  auditLogs  AuditLog[]
  checklists Checklist[]
  executions ChecklistExecution[]

  workshopAreas        WorkshopArea[]
  workshopProducts     WorkshopProduct[]
  workshopMaterials    WorkshopMaterial[]
  workshopPauseReasons WorkshopPauseReason[]
  workshopOrders       WorkshopServiceOrder[]

  @@map("companies")
}

model User {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EXECUTOR)
  platformAdmin       Boolean   @default(false) @map("platform_admin")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  createdAt           DateTime  @default(now()) @map("created_at")
  deletedAt           DateTime? @map("deleted_at")
  deletedBy           Int?      @map("deleted_by")

  company              Company              @relation(fields: [companyId], references: [id])
  legalAcceptances     LegalAcceptance[]
  auditLogs            AuditLog[]
  checklistsCreated    Checklist[]          @relation("ChecklistCreator")
  checklistExecutions  ChecklistExecution[] @relation("ChecklistExecutor")

  workshopOrdersRequested WorkshopServiceOrder[]       @relation("WorkshopOrderRequester")
  workshopOrdersAssigned  WorkshopServiceOrder[]       @relation("WorkshopOrderAssignee")
  workshopOrderLogs       WorkshopOrderLog[]           @relation("WorkshopOrderLogAuthor")
  workshopDeliveries      WorkshopOrderDelivery[]      @relation("WorkshopDeliverer")
  workshopConsumptions    WorkshopMaterialConsumption[] @relation("WorkshopConsumptionCreator")

  @@index([companyId])
  @@map("users")
}

// ─── Auditoria ────────────────────────────────────────────────────

model AuditLog {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  userId        Int       @map("user_id")
  action        String    @db.VarChar(100)
  entity        String?   @db.VarChar(100)
  entityId      Int?      @map("entity_id")
  payloadBefore String?   @db.Text @map("payload_before")
  payloadAfter  String?   @db.Text @map("payload_after")
  ip            String?   @db.VarChar(45)
  createdAt     DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId],    references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Auth: convites e reset de senha ─────────────────────────────

model Invite {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  email       String
  role        Role      @default(EXECUTOR)
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([token])
  @@map("invites")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@map("password_resets")
}

// ─── Documentos legais e aceites ─────────────────────────────────

model LegalVersion {
  id          Int               @id @default(autoincrement())
  type        LegalType
  version     String            @db.VarChar(20)
  summary     String?           @db.Text
  effectiveAt DateTime          @map("effective_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  createdBy   Int               @map("created_by")
  acceptances LegalAcceptance[]

  @@unique([type, version])
  @@index([type, effectiveAt])
  @@map("legal_versions")
}

model LegalAcceptance {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  legalVersionId Int          @map("legal_version_id")
  acceptedAt     DateTime     @default(now()) @map("accepted_at")
  ip             String?      @db.VarChar(45)
  user           User         @relation(fields: [userId], references: [id])
  legalVersion   LegalVersion @relation(fields: [legalVersionId], references: [id])

  @@unique([userId, legalVersionId])
  @@index([userId])
  @@map("legal_acceptances")
}

// ─── Checklists ───────────────────────────────────────────────────

enum FieldType {
  OK_NOK
  SIM_NAO
  NUMERIC
  TEXT
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Checklist {
  id             Int       @id @default(autoincrement())
  companyId      Int?      @map("company_id")        // null = template de plataforma
  name           String    @db.VarChar(200)
  description    String?   @db.Text
  active         Boolean   @default(true)
  isTemplate     Boolean   @default(false) @map("is_template")
  templateSource String?   @db.VarChar(200)          @map("template_source")
  createdBy      Int       @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedBy      Int?      @map("deleted_by")

  company    Company?             @relation(fields: [companyId], references: [id])
  creator    User                 @relation("ChecklistCreator", fields: [createdBy], references: [id])
  items      ChecklistItem[]
  executions ChecklistExecution[]

  @@index([companyId])
  @@map("checklists")
}

// Seção / agrupador de campos (ex.: "Câmara fria 1", "Limpeza")
model ChecklistItem {
  id          Int       @id @default(autoincrement())
  checklistId Int       @map("checklist_id")
  order       Int       @default(0)
  label       String    @db.VarChar(500)
  description String?   @db.Text
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   Int?      @map("deleted_by")

  checklist Checklist           @relation(fields: [checklistId], references: [id])
  fields    ChecklistItemField[]

  @@index([checklistId])
  @@map("checklist_items")
}

// Campo de medição dentro de um item (ex.: "Temperatura", "Prateleiras limpas")
model ChecklistItemField {
  id              Int       @id @default(autoincrement())
  itemId          Int       @map("item_id")
  order           Int       @default(0)
  label           String    @db.VarChar(500)
  description     String?   @db.Text            // instrução/evidência esperada (exibida durante execução)
  type            FieldType @default(OK_NOK)
  unit            String?   @db.VarChar(20)    // ex.: °C, kg, %
  required        Boolean   @default(true)
  requirePhoto    Boolean   @default(false)    @map("require_photo")
  reference       String?   @db.VarChar(100)   // ex.: "5.1.1"
  referenceSource String?   @db.VarChar(200)   @map("reference_source") // ex.: "ISO 9001:2015"
  allowNa         Boolean   @default(false)    @map("allow_na")         // habilita opção N/A
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       Int?      @map("deleted_by")

  item        ChecklistItem        @relation(fields: [itemId], references: [id])
  fieldValues ExecutionFieldValue[]

  @@index([itemId])
  @@map("checklist_item_fields")
}

model ChecklistExecution {
  id                Int             @id @default(autoincrement())
  checklistId       Int             @map("checklist_id")
  companyId         Int             @map("company_id")
  executedBy        Int             @map("executed_by")
  status            ExecutionStatus @default(IN_PROGRESS)
  startedAt         DateTime        @default(now()) @map("started_at")
  finishedAt        DateTime?       @map("finished_at")
  conclusionNote    String?         @db.Text @map("conclusion_note")
  reportUrl         String?         @db.VarChar(500) @map("report_url")
  reportIaUrl       String?         @db.VarChar(500) @map("report_ia_url")
  reportGeneratedAt DateTime?       @map("report_generated_at")
  deletedAt         DateTime?       @map("deleted_at")
  deletedBy         Int?            @map("deleted_by")

  checklist   Checklist            @relation(fields: [checklistId], references: [id])
  company     Company              @relation(fields: [companyId], references: [id])
  executor    User                 @relation("ChecklistExecutor", fields: [executedBy], references: [id])
  fieldValues ExecutionFieldValue[]

  @@index([companyId])
  @@index([checklistId])
  @@index([executedBy])
  @@map("checklist_executions")
}

// Resposta de um campo em uma execução
model ExecutionFieldValue {
  id            Int       @id @default(autoincrement())
  executionId   Int       @map("execution_id")
  fieldId       Int       @map("field_id")
  valueOkNok    Boolean?  @map("value_ok_nok")
  valueNumeric  Decimal?  @db.Decimal(10, 2) @map("value_numeric")
  valueText     String?   @db.Text @map("value_text")
  valueNa       Boolean   @default(false) @map("value_na")  // campo marcado como N/A
  photoUrl      String?   @db.VarChar(500) @map("photo_url")
  annotation    String?   @db.Text
  transcription String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  execution ChecklistExecution @relation(fields: [executionId], references: [id])
  field     ChecklistItemField @relation(fields: [fieldId], references: [id])

  @@unique([executionId, fieldId])
  @@index([executionId])
  @@map("execution_field_values")
}

// ─── Oficina ─────────────────────────────────────────────────────

enum WorkshopOrderStatus {
  NOVO
  EM_ANALISE
  PENDENTE
  EM_PRODUCAO
  ENTREGA_PARCIAL
  CONCLUIDO
  CANCELADO
}

enum WorkshopMaterialSource {
  COMPRADO
  RECICLADO
}

// Departamentos/áreas solicitantes (configurável pela empresa)
model WorkshopArea {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  name      String    @db.VarChar(200)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company Company               @relation(fields: [companyId], references: [id])
  orders  WorkshopServiceOrder[]

  @@index([companyId])
  @@map("workshop_areas")
}

// Catálogo de produtos/serviços que a oficina executa
model WorkshopProduct {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  name      String    @db.VarChar(200)
  category  String?   @db.VarChar(100)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company Company               @relation(fields: [companyId], references: [id])
  orders  WorkshopServiceOrder[]

  @@index([companyId])
  @@map("workshop_products")
}

// Estoque de insumos da oficina
model WorkshopMaterial {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  name        String    @db.VarChar(200)
  unit        String    @db.VarChar(30)         // ex: UN, KG, M, CHAPA, M_LINEAR
  quantity    Decimal   @default(0) @db.Decimal(10, 3)
  minQuantity Decimal   @default(0) @db.Decimal(10, 3) @map("min_quantity")
  unitCost    Decimal?  @db.Decimal(10, 2)      @map("unit_cost") // para cálculo de economia ESG
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt              @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   Int?      @map("deleted_by")

  company      Company                      @relation(fields: [companyId], references: [id])
  consumptions WorkshopMaterialConsumption[]

  @@index([companyId])
  @@map("workshop_materials")
}

// Motivos padronizados de pausa de pedido
model WorkshopPauseReason {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  name      String    @db.VarChar(200)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company Company               @relation(fields: [companyId], references: [id])
  orders  WorkshopServiceOrder[]

  @@index([companyId])
  @@map("workshop_pause_reasons")
}

// Ordem de serviço — entidade principal do módulo
model WorkshopServiceOrder {
  id                Int                 @id @default(autoincrement())
  companyId         Int                 @map("company_id")
  requestedBy       Int                 @map("requested_by")
  assignedTo        Int?                @map("assigned_to")   // operador responsável
  areaId            Int                 @map("area_id")
  productId         Int                 @map("product_id")
  quantity          Int
  quantityDelivered Int                 @default(0)           @map("quantity_delivered")
  desiredDate       DateTime?           @map("desired_date")
  details           String?             @db.Text
  status            WorkshopOrderStatus @default(NOVO)
  pauseReasonId     Int?                @map("pause_reason_id")
  startedAt         DateTime?           @map("started_at")
  finishedAt        DateTime?           @map("finished_at")
  createdAt         DateTime            @default(now())       @map("created_at")
  updatedAt         DateTime            @updatedAt            @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  deletedBy         Int?                @map("deleted_by")

  company      Company                      @relation(fields: [companyId],     references: [id])
  requester    User                         @relation("WorkshopOrderRequester", fields: [requestedBy], references: [id])
  assignee     User?                        @relation("WorkshopOrderAssignee",  fields: [assignedTo],  references: [id])
  area         WorkshopArea                 @relation(fields: [areaId],         references: [id])
  product      WorkshopProduct              @relation(fields: [productId],       references: [id])
  pauseReason  WorkshopPauseReason?         @relation(fields: [pauseReasonId],   references: [id])
  logs         WorkshopOrderLog[]
  deliveries   WorkshopOrderDelivery[]
  attachments  WorkshopOrderAttachment[]
  consumptions WorkshopMaterialConsumption[]

  @@index([companyId])
  @@index([requestedBy])
  @@index([status])
  @@map("workshop_service_orders")
}

// Log de negociação e histórico de status por pedido
model WorkshopOrderLog {
  id         Int                  @id @default(autoincrement())
  orderId    Int                  @map("order_id")
  userId     Int                  @map("user_id")
  message    String               @db.Text
  statusFrom WorkshopOrderStatus? @map("status_from")
  statusTo   WorkshopOrderStatus? @map("status_to")
  createdAt  DateTime             @default(now()) @map("created_at")

  order WorkshopServiceOrder @relation(fields: [orderId], references: [id])
  user  User                 @relation("WorkshopOrderLogAuthor", fields: [userId], references: [id])

  @@index([orderId])
  @@map("workshop_order_logs")
}

// Registros de entrega parcial de um pedido
model WorkshopOrderDelivery {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  quantity    Int
  note        String?  @db.Text
  deliveredBy Int      @map("delivered_by")
  createdAt   DateTime @default(now()) @map("created_at")

  order     WorkshopServiceOrder @relation(fields: [orderId],     references: [id])
  deliverer User                 @relation("WorkshopDeliverer",   fields: [deliveredBy], references: [id])

  @@index([orderId])
  @@map("workshop_order_deliveries")
}

// Fotos e anexos de um pedido
model WorkshopOrderAttachment {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  url       String   @db.VarChar(500)
  fileName  String?  @db.VarChar(200) @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")

  order WorkshopServiceOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("workshop_order_attachments")
}

// Baixa de material por pedido (rastreabilidade ESG)
model WorkshopMaterialConsumption {
  id         Int                    @id @default(autoincrement())
  orderId    Int                    @map("order_id")
  materialId Int                    @map("material_id")
  quantity   Decimal                @db.Decimal(10, 3)
  source     WorkshopMaterialSource @default(COMPRADO)
  note       String?                @db.Text
  createdBy  Int                    @map("created_by")
  createdAt  DateTime               @default(now()) @map("created_at")
  deletedAt  DateTime?              @map("deleted_at")
  deletedBy  Int?                   @map("deleted_by")

  order    WorkshopServiceOrder @relation(fields: [orderId],    references: [id])
  material WorkshopMaterial     @relation(fields: [materialId], references: [id])
  creator  User                 @relation("WorkshopConsumptionCreator", fields: [createdBy], references: [id])

  @@index([orderId])
  @@index([materialId])
  @@map("workshop_material_consumptions")
}

// ─── Módulos habilitados por empresa ─────────────────────────────

model CompanyModule {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  module    String   // checklists | intercorrencias | rastreabilidade | planos | captura
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, module])
  @@index([companyId])
  @@map("company_modules")
}
