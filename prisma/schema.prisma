generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  ADMIN
  GESTOR
  EXECUTOR
  AUDITOR
}

// ─── Core: Empresa e Usuários ─────────────────────────────────────

model Company {
  id          Int       @id @default(autoincrement())
  name        String
  document    String?
  email       String    @unique
  plan        Plan      @default(FREE)
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  suspendedAt DateTime? @map("suspended_at")

  users   User[]
  modules CompanyModule[]

  @@map("companies")
}

model User {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EXECUTOR)
  platformAdmin Boolean   @default(false) @map("platform_admin")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     Int?      @map("deleted_by")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("users")
}

// ─── Auditoria ────────────────────────────────────────────────────

model AuditLog {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  userId        Int       @map("user_id")
  action        String
  entity        String?
  entityId      Int?      @map("entity_id")
  payloadBefore String?   @db.Text @map("payload_before")
  payloadAfter  String?   @db.Text @map("payload_after")
  ip            String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Auth: convites e reset de senha ─────────────────────────────

model Invite {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  email       String
  role        Role      @default(EXECUTOR)
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([token])
  @@map("invites")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@map("password_resets")
}

// ─── Módulos habilitados por empresa ─────────────────────────────

model CompanyModule {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  module    String   // checklists | intercorrencias | rastreabilidade | planos | captura
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, module])
  @@index([companyId])
  @@map("company_modules")
}
