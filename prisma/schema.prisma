generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────

enum LegalType {
  TERMS
  PRIVACY
}

enum EfetivoModoPadrao {
  FIXO_SEMANAL
  ROTATIVO
}

enum EfetivoStatusColaborador {
  ATIVO
  DESLIGADO
}

enum EfetivoTipoMovimentacao {
  ADMISSAO
  DESLIGAMENTO
  READMISSAO
}

enum EfetivoTipoEvento {
  FERIAS
  FOLGA_FERIADO
  FOLGA_DOMINICAL
  ATESTADO
  AFASTAMENTO_INSS
  FALTA_JUSTIFICADA
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum Role {
  ADMIN
  GESTOR
  EXECUTOR
  AUDITOR
}

// ─── Core: Empresa e Usuários ─────────────────────────────────────

model Company {
  id          Int       @id @default(autoincrement())
  name        String
  document    String?
  email       String    @unique
  plan        Plan      @default(FREE)
  maxUsers    Int?      @map("max_users")   // null = usa o limite padrão do plano
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")
  suspendedAt  DateTime? @map("suspended_at")
  featureAudio Boolean   @default(false) @map("feature_audio")

  users            User[]
  modules          CompanyModule[]
  userModuleAccess UserModuleAccess[]
  auditLogs        AuditLog[]
  checklists Checklist[]
  executions ChecklistExecution[]

  workshopAreas        WorkshopArea[]
  workshopProducts     WorkshopProduct[]
  workshopMaterials    WorkshopMaterial[]
  workshopPauseReasons WorkshopPauseReason[]
  workshopOrders       WorkshopServiceOrder[]

  efetivoTurnos          EfetivoTurno[]
  efetivoPadroes         EfetivoPadraoEscala[]
  efetivoAreas           EfetivoArea[]
  efetivoCargos          EfetivoCargo[]
  efetivoColaboradores   EfetivoColaborador[]
  efetivoTiposOcorrencia EfetivoTipoOcorrencia[]
  efetivoMovimentacoes   EfetivoMovimentacaoVinculo[]
  efetivoOcorrencias     EfetivoOcorrencia[]
  efetivoEncarregados    EfetivoEncarregado[]
  efetivoEventos         EfetivoEvento[]
  efetivoSnapshots       EfetivoSnapshot[]

  @@map("companies")
}

model User {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EXECUTOR)
  platformAdmin       Boolean   @default(false) @map("platform_admin")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  createdAt           DateTime  @default(now()) @map("created_at")
  deletedAt           DateTime? @map("deleted_at")
  deletedBy           Int?      @map("deleted_by")

  company              Company              @relation(fields: [companyId], references: [id])
  legalAcceptances     LegalAcceptance[]
  auditLogs            AuditLog[]
  checklistsCreated    Checklist[]          @relation("ChecklistCreator")
  checklistExecutions  ChecklistExecution[] @relation("ChecklistExecutor")

  workshopOrdersRequested WorkshopServiceOrder[]       @relation("WorkshopOrderRequester")
  workshopOrdersAssigned  WorkshopServiceOrder[]       @relation("WorkshopOrderAssignee")
  workshopOrderLogs       WorkshopOrderLog[]           @relation("WorkshopOrderLogAuthor")
  workshopDeliveries      WorkshopOrderDelivery[]      @relation("WorkshopDeliverer")
  workshopConsumptions    WorkshopMaterialConsumption[] @relation("WorkshopConsumptionCreator")

  moduleAccess        UserModuleAccess[] @relation("UMAUser")
  moduleAccessGranted UserModuleAccess[] @relation("UMAGrantor")

  efetivoColaborador   EfetivoColaborador?          @relation("EfetivoUser")
  efetivoMovimentacoes EfetivoMovimentacaoVinculo[] @relation("MovimentacaoRegistradaPor")
  efetivoOcorrencias   EfetivoOcorrencia[]          @relation("OcorrenciaRegistradaPor")
  efetivoEventos       EfetivoEvento[]              @relation("EventoCriadoPor")
  efetivoSnapshots     EfetivoSnapshot[]            @relation("SnapshotPublicador")

  @@index([companyId])
  @@map("users")
}

// ─── Auditoria ────────────────────────────────────────────────────

model AuditLog {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  userId        Int       @map("user_id")
  action        String    @db.VarChar(100)
  entity        String?   @db.VarChar(100)
  entityId      Int?      @map("entity_id")
  payloadBefore String?   @db.Text @map("payload_before")
  payloadAfter  String?   @db.Text @map("payload_after")
  ip            String?   @db.VarChar(45)
  createdAt     DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId],    references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Auth: convites e reset de senha ─────────────────────────────

model Invite {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  email       String
  role        Role      @default(EXECUTOR)
  token       String    @unique
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([companyId])
  @@index([token])
  @@map("invites")
}

model PasswordReset {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@map("password_resets")
}

// ─── Documentos legais e aceites ─────────────────────────────────

model LegalVersion {
  id          Int               @id @default(autoincrement())
  type        LegalType
  version     String            @db.VarChar(20)
  summary     String?           @db.Text
  effectiveAt DateTime          @map("effective_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  createdBy   Int               @map("created_by")
  acceptances LegalAcceptance[]

  @@unique([type, version])
  @@index([type, effectiveAt])
  @@map("legal_versions")
}

model LegalAcceptance {
  id             Int          @id @default(autoincrement())
  userId         Int          @map("user_id")
  legalVersionId Int          @map("legal_version_id")
  acceptedAt     DateTime     @default(now()) @map("accepted_at")
  ip             String?      @db.VarChar(45)
  user           User         @relation(fields: [userId], references: [id])
  legalVersion   LegalVersion @relation(fields: [legalVersionId], references: [id])

  @@unique([userId, legalVersionId])
  @@index([userId])
  @@map("legal_acceptances")
}

// ─── Checklists ───────────────────────────────────────────────────

enum FieldType {
  OK_NOK
  SIM_NAO
  NUMERIC
  TEXT
}

enum ExecutionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Checklist {
  id             Int       @id @default(autoincrement())
  companyId      Int?      @map("company_id")        // null = template de plataforma
  name           String    @db.VarChar(200)
  description    String?   @db.Text
  active         Boolean   @default(true)
  isTemplate     Boolean   @default(false) @map("is_template")
  templateSource String?   @db.VarChar(200)          @map("template_source")
  createdBy      Int       @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedBy      Int?      @map("deleted_by")

  company    Company?             @relation(fields: [companyId], references: [id])
  creator    User                 @relation("ChecklistCreator", fields: [createdBy], references: [id])
  items      ChecklistItem[]
  executions ChecklistExecution[]

  @@index([companyId])
  @@map("checklists")
}

// Seção / agrupador de campos (ex.: "Câmara fria 1", "Limpeza")
model ChecklistItem {
  id          Int       @id @default(autoincrement())
  checklistId Int       @map("checklist_id")
  order       Int       @default(0)
  label       String    @db.VarChar(500)
  description String?   @db.Text
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   Int?      @map("deleted_by")

  checklist  Checklist            @relation(fields: [checklistId], references: [id])
  fields     ChecklistItemField[]
  itemNotes  ExecutionItemNote[]

  @@index([checklistId])
  @@map("checklist_items")
}

// Campo de medição dentro de um item (ex.: "Temperatura", "Prateleiras limpas")
model ChecklistItemField {
  id              Int       @id @default(autoincrement())
  itemId          Int       @map("item_id")
  order           Int       @default(0)
  label           String    @db.VarChar(500)
  description     String?   @db.Text            // instrução/evidência esperada (exibida durante execução)
  type            FieldType @default(OK_NOK)
  unit            String?   @db.VarChar(20)    // ex.: °C, kg, %
  required        Boolean   @default(true)
  requirePhoto    Boolean   @default(false)    @map("require_photo")
  reference       String?   @db.VarChar(100)   // ex.: "5.1.1"
  referenceSource String?   @db.VarChar(200)   @map("reference_source") // ex.: "ISO 9001:2015"
  allowNa         Boolean   @default(false)    @map("allow_na")         // habilita opção N/A
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       Int?      @map("deleted_by")

  item        ChecklistItem        @relation(fields: [itemId], references: [id])
  fieldValues ExecutionFieldValue[]

  @@index([itemId])
  @@map("checklist_item_fields")
}

model ChecklistExecution {
  id                Int             @id @default(autoincrement())
  checklistId       Int             @map("checklist_id")
  companyId         Int             @map("company_id")
  executedBy        Int             @map("executed_by")
  status            ExecutionStatus @default(IN_PROGRESS)
  startedAt         DateTime        @default(now()) @map("started_at")
  finishedAt        DateTime?       @map("finished_at")
  conclusionNote    String?         @db.Text @map("conclusion_note")
  reportUrl         String?         @db.VarChar(500) @map("report_url")
  reportIaUrl       String?         @db.VarChar(500) @map("report_ia_url")
  reportGeneratedAt DateTime?       @map("report_generated_at")
  deletedAt         DateTime?       @map("deleted_at")
  deletedBy         Int?            @map("deleted_by")

  checklist   Checklist             @relation(fields: [checklistId], references: [id])
  company     Company               @relation(fields: [companyId], references: [id])
  executor    User                  @relation("ChecklistExecutor", fields: [executedBy], references: [id])
  fieldValues ExecutionFieldValue[]
  itemNotes   ExecutionItemNote[]

  @@index([companyId])
  @@index([checklistId])
  @@index([executedBy])
  @@map("checklist_executions")
}

// Resposta de um campo em uma execução
model ExecutionFieldValue {
  id            Int       @id @default(autoincrement())
  executionId   Int       @map("execution_id")
  fieldId       Int       @map("field_id")
  valueOkNok    Boolean?  @map("value_ok_nok")
  valueNumeric  Decimal?  @db.Decimal(10, 2) @map("value_numeric")
  valueText     String?   @db.Text @map("value_text")
  valueNa       Boolean   @default(false) @map("value_na")  // campo marcado como N/A
  photoUrl      String?   @db.VarChar(500) @map("photo_url")
  annotation    String?   @db.Text
  transcription String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  execution ChecklistExecution @relation(fields: [executionId], references: [id])
  field     ChecklistItemField @relation(fields: [fieldId], references: [id])

  @@unique([executionId, fieldId])
  @@index([executionId])
  @@map("execution_field_values")
}

// Foto/áudio/anotação registrados por item (não por campo)
model ExecutionItemNote {
  id            Int      @id @default(autoincrement())
  executionId   Int      @map("execution_id")
  itemId        Int      @map("item_id")
  photoUrl      String?  @db.VarChar(500) @map("photo_url")
  annotation    String?  @db.Text
  transcription String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  execution ChecklistExecution @relation(fields: [executionId], references: [id])
  item      ChecklistItem      @relation(fields: [itemId], references: [id])

  @@unique([executionId, itemId])
  @@index([executionId])
  @@map("execution_item_notes")
}

// ─── Oficina ─────────────────────────────────────────────────────

enum WorkshopOrderStatus {
  NOVO
  EM_ANALISE
  PENDENTE
  EM_PRODUCAO
  ENTREGA_PARCIAL
  CONCLUIDO
  CANCELADO
}

enum WorkshopMaterialSource {
  COMPRADO
  RECICLADO
}

// Departamentos/áreas solicitantes (configurável pela empresa)
model WorkshopArea {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  name      String    @db.VarChar(200)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company Company               @relation(fields: [companyId], references: [id])
  orders  WorkshopServiceOrder[]

  @@index([companyId])
  @@map("workshop_areas")
}

// Catálogo de produtos/serviços que a oficina executa
model WorkshopProduct {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  name      String    @db.VarChar(200)
  category  String?   @db.VarChar(100)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company Company               @relation(fields: [companyId], references: [id])
  orders  WorkshopServiceOrder[]

  @@index([companyId])
  @@map("workshop_products")
}

// Estoque de insumos da oficina
model WorkshopMaterial {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  name        String    @db.VarChar(200)
  unit        String    @db.VarChar(30)         // ex: UN, KG, M, CHAPA, M_LINEAR
  quantity    Decimal   @default(0) @db.Decimal(10, 3)
  minQuantity Decimal   @default(0) @db.Decimal(10, 3) @map("min_quantity")
  unitCost    Decimal?  @db.Decimal(10, 2)      @map("unit_cost") // para cálculo de economia ESG
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt              @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   Int?      @map("deleted_by")

  company      Company                      @relation(fields: [companyId], references: [id])
  consumptions WorkshopMaterialConsumption[]

  @@index([companyId])
  @@map("workshop_materials")
}

// Motivos padronizados de pausa de pedido
model WorkshopPauseReason {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  name      String    @db.VarChar(200)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company Company               @relation(fields: [companyId], references: [id])
  orders  WorkshopServiceOrder[]

  @@index([companyId])
  @@map("workshop_pause_reasons")
}

// Ordem de serviço — entidade principal do módulo
model WorkshopServiceOrder {
  id                Int                 @id @default(autoincrement())
  companyId         Int                 @map("company_id")
  requestedBy       Int                 @map("requested_by")
  assignedTo        Int?                @map("assigned_to")   // operador responsável
  areaId            Int                 @map("area_id")
  productId         Int                 @map("product_id")
  quantity          Int
  quantityDelivered Int                 @default(0)           @map("quantity_delivered")
  desiredDate       DateTime?           @map("desired_date")
  details           String?             @db.Text
  status            WorkshopOrderStatus @default(NOVO)
  pauseReasonId     Int?                @map("pause_reason_id")
  startedAt         DateTime?           @map("started_at")
  finishedAt        DateTime?           @map("finished_at")
  createdAt         DateTime            @default(now())       @map("created_at")
  updatedAt         DateTime            @updatedAt            @map("updated_at")
  deletedAt         DateTime?           @map("deleted_at")
  deletedBy         Int?                @map("deleted_by")

  company      Company                      @relation(fields: [companyId],     references: [id])
  requester    User                         @relation("WorkshopOrderRequester", fields: [requestedBy], references: [id])
  assignee     User?                        @relation("WorkshopOrderAssignee",  fields: [assignedTo],  references: [id])
  area         WorkshopArea                 @relation(fields: [areaId],         references: [id])
  product      WorkshopProduct              @relation(fields: [productId],       references: [id])
  pauseReason  WorkshopPauseReason?         @relation(fields: [pauseReasonId],   references: [id])
  logs         WorkshopOrderLog[]
  deliveries   WorkshopOrderDelivery[]
  attachments  WorkshopOrderAttachment[]
  consumptions WorkshopMaterialConsumption[]

  @@index([companyId])
  @@index([requestedBy])
  @@index([status])
  @@map("workshop_service_orders")
}

// Log de negociação e histórico de status por pedido
model WorkshopOrderLog {
  id         Int                  @id @default(autoincrement())
  orderId    Int                  @map("order_id")
  userId     Int                  @map("user_id")
  message    String               @db.Text
  statusFrom WorkshopOrderStatus? @map("status_from")
  statusTo   WorkshopOrderStatus? @map("status_to")
  createdAt  DateTime             @default(now()) @map("created_at")

  order WorkshopServiceOrder @relation(fields: [orderId], references: [id])
  user  User                 @relation("WorkshopOrderLogAuthor", fields: [userId], references: [id])

  @@index([orderId])
  @@map("workshop_order_logs")
}

// Registros de entrega parcial de um pedido
model WorkshopOrderDelivery {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  quantity    Int
  note        String?  @db.Text
  deliveredBy Int      @map("delivered_by")
  createdAt   DateTime @default(now()) @map("created_at")

  order     WorkshopServiceOrder @relation(fields: [orderId],     references: [id])
  deliverer User                 @relation("WorkshopDeliverer",   fields: [deliveredBy], references: [id])

  @@index([orderId])
  @@map("workshop_order_deliveries")
}

// Fotos e anexos de um pedido
model WorkshopOrderAttachment {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  url       String   @db.VarChar(500)
  fileName  String?  @db.VarChar(200) @map("file_name")
  createdAt DateTime @default(now()) @map("created_at")

  order WorkshopServiceOrder @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("workshop_order_attachments")
}

// Baixa de material por pedido (rastreabilidade ESG)
model WorkshopMaterialConsumption {
  id         Int                    @id @default(autoincrement())
  orderId    Int                    @map("order_id")
  materialId Int                    @map("material_id")
  quantity   Decimal                @db.Decimal(10, 3)
  source     WorkshopMaterialSource @default(COMPRADO)
  note       String?                @db.Text
  createdBy  Int                    @map("created_by")
  createdAt  DateTime               @default(now()) @map("created_at")
  deletedAt  DateTime?              @map("deleted_at")
  deletedBy  Int?                   @map("deleted_by")

  order    WorkshopServiceOrder @relation(fields: [orderId],    references: [id])
  material WorkshopMaterial     @relation(fields: [materialId], references: [id])
  creator  User                 @relation("WorkshopConsumptionCreator", fields: [createdBy], references: [id])

  @@index([orderId])
  @@index([materialId])
  @@map("workshop_material_consumptions")
}

// ─── Acesso por módulo por usuário ───────────────────────────────

model UserModuleAccess {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  companyId Int      @map("company_id")
  moduleKey String   @db.VarChar(50) @map("module_key")
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy Int?     @map("granted_by")

  user    User    @relation("UMAUser",    fields: [userId],    references: [id])
  company Company @relation(            fields: [companyId], references: [id])
  grantor User?   @relation("UMAGrantor", fields: [grantedBy], references: [id])

  @@unique([userId, moduleKey])
  @@index([userId])
  @@index([companyId])
  @@map("user_module_access")
}

// ─── Controle de Efetivo ─────────────────────────────────────────

model EfetivoTurno {
  id             Int       @id @default(autoincrement())
  companyId      Int       @map("company_id")
  codigo         String    @db.VarChar(10)
  horaInicio     String    @db.VarChar(5)  @map("hora_inicio")
  horaFim        String    @db.VarChar(5)  @map("hora_fim")
  cruzaMeiaNoite Boolean   @default(false) @map("cruza_meia_noite")
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedBy      Int?      @map("deleted_by")

  company         Company                  @relation(fields: [companyId], references: [id])
  colaboradores   EfetivoColaborador[]
  escalaPublicada EfetivoEscalaPublicada[]

  @@unique([companyId, codigo])
  @@index([companyId])
  @@map("efetivo_turnos")
}

model EfetivoPadraoEscala {
  id           Int               @id @default(autoincrement())
  companyId    Int               @map("company_id")
  nome         String            @db.VarChar(100)
  modo         EfetivoModoPadrao
  diasSemana   String?           @db.VarChar(50) @map("dias_semana")
  diasTrabalho Int?              @map("dias_trabalho")
  diasFolga    Int?              @map("dias_folga")
  ativo        Boolean           @default(true)
  createdAt    DateTime          @default(now()) @map("created_at")
  deletedAt    DateTime?         @map("deleted_at")
  deletedBy    Int?              @map("deleted_by")

  company       Company              @relation(fields: [companyId], references: [id])
  colaboradores EfetivoColaborador[]

  @@index([companyId])
  @@map("efetivo_padroes_escala")
}

model EfetivoArea {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  nome      String    @db.VarChar(200)
  areaPaiId Int?      @map("area_pai_id")
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company       Company              @relation(fields: [companyId], references: [id])
  areaPai       EfetivoArea?         @relation("AreaHierarquia", fields: [areaPaiId], references: [id])
  subareas      EfetivoArea[]        @relation("AreaHierarquia")
  colaboradores EfetivoColaborador[]

  @@index([companyId])
  @@index([areaPaiId])
  @@map("efetivo_areas")
}

model EfetivoCargo {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  nome      String    @db.VarChar(200)
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company       Company              @relation(fields: [companyId], references: [id])
  colaboradores EfetivoColaborador[]

  @@index([companyId])
  @@map("efetivo_cargos")
}

model EfetivoColaborador {
  id               Int                      @id @default(autoincrement())
  companyId        Int                      @map("company_id")
  matricula        String                   @db.VarChar(20)
  nome             String                   @db.VarChar(200)
  cargoId          Int                      @map("cargo_id")
  areaId           Int                      @map("area_id")
  padraoEscalaId   Int                      @map("padrao_escala_id")
  turnoId          Int                      @map("turno_id")
  dataAncora       DateTime?                @db.Date @map("data_ancora")
  status           EfetivoStatusColaborador @default(ATIVO)
  dataAdmissao     DateTime                 @db.Date @map("data_admissao")
  dataDesligamento DateTime?                @db.Date @map("data_desligamento")
  userId           Int?                     @unique @map("user_id")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  deletedAt        DateTime?                @map("deleted_at")
  deletedBy        Int?                     @map("deleted_by")

  company        Company                      @relation(fields: [companyId],     references: [id])
  cargo          EfetivoCargo                 @relation(fields: [cargoId],        references: [id])
  area           EfetivoArea                  @relation(fields: [areaId],         references: [id])
  padraoEscala   EfetivoPadraoEscala          @relation(fields: [padraoEscalaId], references: [id])
  turno          EfetivoTurno                 @relation(fields: [turnoId],        references: [id])
  user           User?                        @relation("EfetivoUser", fields: [userId], references: [id])
  movimentacoes  EfetivoMovimentacaoVinculo[]
  ocorrencias    EfetivoOcorrencia[]
  encarregado    EfetivoEncarregado?          @relation("EncarregadoColaborador")
  comoSubstituto EfetivoSubstitutoEncarregado[]
  vinculo        EfetivoVinculoColaborador?   @relation("VinculoColaborador")
  eventos        EfetivoEvento[]
  escalaPublicada EfetivoEscalaPublicada[]

  @@unique([companyId, matricula])
  @@index([companyId])
  @@index([cargoId])
  @@index([areaId])
  @@index([turnoId])
  @@map("efetivo_colaboradores")
}

model EfetivoMovimentacaoVinculo {
  id            Int                     @id @default(autoincrement())
  companyId     Int                     @map("company_id")
  colaboradorId Int                     @map("colaborador_id")
  tipo          EfetivoTipoMovimentacao
  data          DateTime                @db.Date
  motivo        String?                 @db.Text
  registradoPor Int                     @map("registrado_por")
  createdAt     DateTime                @default(now()) @map("created_at")
  deletedAt     DateTime?               @map("deleted_at")
  deletedBy     Int?                    @map("deleted_by")

  company     Company            @relation(fields: [companyId],     references: [id])
  colaborador EfetivoColaborador @relation(fields: [colaboradorId], references: [id])
  registrador User               @relation("MovimentacaoRegistradaPor", fields: [registradoPor], references: [id])

  @@index([companyId])
  @@index([colaboradorId])
  @@map("efetivo_movimentacoes_vinculo")
}

model EfetivoTipoOcorrencia {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  nome      String    @db.VarChar(200)
  ativo     Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  company     Company             @relation(fields: [companyId], references: [id])
  ocorrencias EfetivoOcorrencia[]

  @@index([companyId])
  @@map("efetivo_tipos_ocorrencia")
}

model EfetivoOcorrencia {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  colaboradorId Int       @map("colaborador_id")
  tipoId        Int       @map("tipo_id")
  data          DateTime  @db.Date
  descricao     String    @db.Text
  anexoUrl      String?   @db.VarChar(500) @map("anexo_url")
  registradoPor Int       @map("registrado_por")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     Int?      @map("deleted_by")

  company     Company               @relation(fields: [companyId],     references: [id])
  colaborador EfetivoColaborador    @relation(fields: [colaboradorId], references: [id])
  tipo        EfetivoTipoOcorrencia @relation(fields: [tipoId],        references: [id])
  registrador User                  @relation("OcorrenciaRegistradaPor", fields: [registradoPor], references: [id])

  @@index([companyId])
  @@index([colaboradorId])
  @@map("efetivo_ocorrencias")
}

model EfetivoEncarregado {
  id            Int       @id @default(autoincrement())
  companyId     Int       @map("company_id")
  colaboradorId Int       @unique @map("colaborador_id")
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     Int?      @map("deleted_by")

  company     Company                        @relation(fields: [companyId],     references: [id])
  colaborador EfetivoColaborador             @relation("EncarregadoColaborador", fields: [colaboradorId], references: [id])
  substitutos EfetivoSubstitutoEncarregado[]
  vinculos    EfetivoVinculoColaborador[]

  @@index([companyId])
  @@map("efetivo_encarregados")
}

// Sem soft delete — tabela de configuracao N:N (max 3 substitutos por encarregado)
model EfetivoSubstitutoEncarregado {
  id            Int      @id @default(autoincrement())
  encarregadoId Int      @map("encarregado_id")
  colaboradorId Int      @map("colaborador_id")
  ordem         Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  encarregado EfetivoEncarregado @relation(fields: [encarregadoId], references: [id])
  colaborador EfetivoColaborador @relation(fields: [colaboradorId], references: [id])

  @@unique([encarregadoId, colaboradorId])
  @@index([encarregadoId])
  @@map("efetivo_substitutos_encarregado")
}

model EfetivoVinculoColaborador {
  id            Int       @id @default(autoincrement())
  colaboradorId Int       @unique @map("colaborador_id")
  encarregadoId Int       @map("encarregado_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     Int?      @map("deleted_by")

  colaborador EfetivoColaborador @relation("VinculoColaborador", fields: [colaboradorId], references: [id])
  encarregado EfetivoEncarregado @relation(fields: [encarregadoId], references: [id])

  @@index([encarregadoId])
  @@map("efetivo_vinculos_colaborador")
}

model EfetivoEvento {
  id            Int               @id @default(autoincrement())
  companyId     Int               @map("company_id")
  colaboradorId Int               @map("colaborador_id")
  tipo          EfetivoTipoEvento
  dataInicio    DateTime          @db.Date @map("data_inicio")
  dataFim       DateTime          @db.Date @map("data_fim")
  observacao    String?           @db.Text
  criadoPor     Int               @map("criado_por")
  createdAt     DateTime          @default(now()) @map("created_at")
  deletedAt     DateTime?         @map("deleted_at")
  deletedBy     Int?              @map("deleted_by")

  company     Company            @relation(fields: [companyId],     references: [id])
  colaborador EfetivoColaborador @relation(fields: [colaboradorId], references: [id])
  criador     User               @relation("EventoCriadoPor", fields: [criadoPor], references: [id])

  @@index([companyId])
  @@index([colaboradorId])
  @@index([dataInicio])
  @@map("efetivo_eventos")
}

model EfetivoSnapshot {
  id           Int      @id @default(autoincrement())
  companyId    Int      @map("company_id")
  mes          String   @db.VarChar(7)
  publicadoPor Int      @map("publicado_por")
  publicadoEm  DateTime @default(now()) @map("publicado_em")

  company    Company                  @relation(fields: [companyId],    references: [id])
  publicador User                     @relation("SnapshotPublicador", fields: [publicadoPor], references: [id])
  linhas     EfetivoEscalaPublicada[]

  @@unique([companyId, mes])
  @@index([companyId])
  @@map("efetivo_snapshots")
}

model EfetivoEscalaPublicada {
  id            Int      @id @default(autoincrement())
  snapshotId    Int      @map("snapshot_id")
  colaboradorId Int      @map("colaborador_id")
  data          DateTime @db.Date
  turnoId       Int      @map("turno_id")
  status        String   @db.VarChar(20)

  snapshot    EfetivoSnapshot    @relation(fields: [snapshotId],    references: [id])
  colaborador EfetivoColaborador @relation(fields: [colaboradorId], references: [id])
  turno       EfetivoTurno       @relation(fields: [turnoId],       references: [id])

  @@unique([snapshotId, colaboradorId, data])
  @@index([snapshotId])
  @@index([colaboradorId])
  @@map("efetivo_escala_publicada")
}

// ─── Módulos habilitados por empresa ─────────────────────────────

model CompanyModule {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  module    String   // checklists | intercorrencias | rastreabilidade | planos | captura
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, module])
  @@index([companyId])
  @@map("company_modules")
}
