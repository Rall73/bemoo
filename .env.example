# Banco de dados — usar IP do servidor Hostinger, nunca localhost
DATABASE_URL="mysql://USUARIO:SENHA@IP_DO_SERVIDOR:3306/NOME_DO_BANCO"

# Auth.js — gerar com: openssl rand -base64 32
AUTH_SECRET="GERAR_COM_OPENSSL_RAND"

# Google OAuth (opcional)
AUTH_GOOGLE_ID="seu-google-client-id"
AUTH_GOOGLE_SECRET="seu-google-client-secret"

# URL pública
NEXTAUTH_URL="https://bemoo.com.br"
